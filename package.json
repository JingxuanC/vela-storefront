{
  "name": "vela-storefront",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n remix,spa -c cyan,magenta \"remix vite:dev\" \"cd spa && npm run dev\"",
    "build": "cd spa && npm run build && remix vite:build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --ext .ts,.tsx app/",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@grafana/faro-web-sdk": "^2.7.1",
    "@grafana/faro-web-tracing": "^2.7.1",
    "@preact/signals": "^2.9.1",
    "@remix-run/node": "^2.15.0",
    "@remix-run/react": "^2.15.0",
    "@remix-run/serve": "^2.15.0",
    "chart.js": "^4.4.7",
    "ioredis": "^5.4.1",
    "isbot": "^4",
    "preact": "^10.29.2",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@remix-run/dev": "^2.15.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "concurrently": "^10.0.3",
    "eslint": "^8.57.1",
    "playwright": "^1.60.0",
    "typescript": "^5.6.3"
  }
}
